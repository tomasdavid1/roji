# Roji Protocol Engine — environment variables
#
# Copy this file to .env.local and fill in real values.

# Public storefront URL (used to deep-link to the WooCommerce cart)
NEXT_PUBLIC_STORE_URL=https://rojipeptides.com

# Google Ads conversion tracking (gtag.js). Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_ID=

# Google Ads conversion label for "protocol_complete" micro-conversion.
# Format: aBcDeF1GhIjKlMnO
NEXT_PUBLIC_GADS_PROTOCOL_LABEL=

# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=
