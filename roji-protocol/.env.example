# Roji Protocol Engine — environment variables
#
# Copy this file to .env.local and fill in real values.

# Public storefront URL (used to deep-link to the WooCommerce cart)
NEXT_PUBLIC_STORE_URL=https://rojipeptides.com

# Google Ads conversion tracking (gtag.js). Format: AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_ID=

# Google Ads conversion label for "protocol_complete" micro-conversion.
# Format: aBcDeF1GhIjKlMnO
NEXT_PUBLIC_GADS_PROTOCOL_LABEL=

# Google Ads conversion label for "lead_capture" event used in TEST_MODE.
# Optional — only required if PROTOCOL_TEST_MODE=1 and you want this event
# to count as a Google Ads conversion.
NEXT_PUBLIC_GADS_LEAD_LABEL=

# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# Comma-separated list of domains the gtag linker should bridge. Defaults
# to the production pair; override locally to test cross-subdomain.
NEXT_PUBLIC_GTAG_LINKER_DOMAINS=rojipeptides.com,protocol.rojipeptides.com

# When set to "1", the protocol output replaces the live "Get this stack"
# button with an email-capture lead form. Use this to run Google Ads
# against the protocol engine before products are listed/payment is wired.
NEXT_PUBLIC_PROTOCOL_TEST_MODE=

# Optional: where lead captures get forwarded (Slack / Zapier / your own).
# Receives a JSON POST: { ts, email, stack, ip, user_agent }
ROJI_LEAD_WEBHOOK_URL=

# Optional: file path for lead-capture local log. Defaults to .roji-leads.jsonl
# locally and /tmp/roji-leads.jsonl on Vercel.
LEAD_LOG_FILE=
