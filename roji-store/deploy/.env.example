# Kinsta SSH/SFTP credentials for the rojipeptides.com production environment.
#
# Where to find these in MyKinsta:
#   1. https://my.kinsta.com  → WordPress sites → roji (or whatever you named it)
#   2. Click "Info" tab in the left sidebar
#   3. Scroll to "SFTP/SSH" — copy host, port, username, password from there
#
# After filling this in:
#   cp .env.example .env
#   chmod 600 .env
#
# .env is git-ignored so secrets never reach the repo.

KINSTA_SSH_HOST=
KINSTA_SSH_PORT=
KINSTA_SSH_USER=
KINSTA_SSH_PASSWORD=

# Absolute path on the Kinsta server where WP is installed. For Kinsta this is
# always /www/<sitename>_NNN/public — you'll see it in the SFTP Info tab as the
# default landing directory after SFTP login. Example:
#   KINSTA_WP_PATH=/www/rojipeptides_123/public
KINSTA_WP_PATH=

# Production URL used for search-replace during db-push.sh.
KINSTA_SITE_URL=https://rojipeptides.com

# Local LocalWP DB credentials (do not change unless you reconfigured LocalWP).
LOCAL_DB_NAME=local
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=root
LOCAL_DB_SOCKET=/Users/tomas/Library/Application Support/Local/run/JCRz5TJ0A/mysql/mysqld.sock

# LocalWP site URL (must match what's in wp_options.siteurl on the local DB).
LOCAL_SITE_URL=http://roji.local

# Path to LocalWP site (used to read uploads).
LOCAL_WP_PATH=/Users/tomas/Local Sites/roji/app/public
