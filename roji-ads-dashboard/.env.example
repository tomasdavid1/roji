# Roji Ads Dashboard — environment variables
#
# Copy to .env.local and fill in real values.
# When any of GOOGLE_ADS_* are missing, the dashboard runs against mock data
# so you can develop the UI without live credentials.

# Google Ads API credentials.
# Apply for a developer token at https://ads.google.com/api
# Create OAuth client at https://console.cloud.google.com/apis/credentials
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Customer ID (format: 1234567890, no dashes).
# Production: 6573032286 (Roji Tools sub-account, 657-303-2286).
GOOGLE_ADS_CUSTOMER_ID=

# Manager (MCC) ID, no dashes. Required because Roji Tools lives under a
# manager account. Production: 2637832527 (263-783-2527).
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Basic-auth gate for the dashboard (placeholder until proper OAuth)
ADMIN_USER=admin
ADMIN_PASS=change-me-immediately

# Cron auth — required in production for /api/cron/* endpoints.
# Vercel Cron sends this as `Authorization: Bearer ${CRON_SECRET}`.
# Leave blank locally to allow manual hits without auth.
# Generate: openssl rand -hex 32
CRON_SECRET=

# Roji store internal API — used to read aggregate subscription + affiliate
# metrics (MRR, churn, GMV, commissions) from the WP install. Same token
# must be set on WP side via
# `define( 'ROJI_INTERNAL_API_TOKEN', '...' );` in wp-config.php.
# Generate: openssl rand -hex 32
ROJI_STORE_URL=https://rojipeptides.com
ROJI_INTERNAL_API_TOKEN=

# Tracking-page surface (the /tracking checklist reads these to render
# the env-state card and to compute the "URL to check" for each probe).
# These are public IDs — no secrets — and only used for display.
#
# Production values (Roji Tools 657-303-2286, account-specific gtag):
#   NEXT_PUBLIC_GADS_ID=AW-18130000394
#   NEXT_PUBLIC_GADS_PURCHASE_LABEL=5UzRCPbFlqUcEIq0h8VD
#   NEXT_PUBLIC_GADS_ADD_TO_CART_LABEL=zMB-CJPUlqUcEIq0h8VD
NEXT_PUBLIC_GADS_ID=
NEXT_PUBLIC_GADS_PURCHASE_LABEL=
NEXT_PUBLIC_GADS_ADD_TO_CART_LABEL=

# Optional / future: macro tool-completion conversion (not currently wired —
# campaigns optimize on `purchase`, not `tool_complete`). Keep empty unless
# you spin up a separate lead-gen campaign that wants the softer signal.
NEXT_PUBLIC_GADS_TOOL_COMPLETE_LABEL=

NEXT_PUBLIC_GADS_LEAD_LABEL=
NEXT_PUBLIC_GA4_ID=

# Research Tools surface (formerly "protocol engine"). Live at
# tools.rojipeptides.com under the "Research Tools" framing — do not
# reintroduce "protocol" in customer-facing copy. Legacy env names
# (NEXT_PUBLIC_PROTOCOL_URL / NEXT_PUBLIC_PROTOCOL_TEST_MODE) are still
# honored as fallbacks; prefer the new names below for new deploys.
NEXT_PUBLIC_TOOLS_URL=https://tools.rojipeptides.com
NEXT_PUBLIC_TOOLS_TEST_MODE=

# Trustpilot Business API — for the reviews summary on /performance.
# Get values from https://businessapp.b2b.trustpilot.com/ → Integrations → API access.
# - BUSINESS_UNIT_ID is public (used in widget HTML on the storefront too).
# - API_KEY + API_SECRET are server-side secrets (client_credentials grant).
# - BUSINESS_USER_ID is the user the API calls run as (Admin or Manager role).
TRUSTPILOT_BUSINESS_UNIT_ID=
TRUSTPILOT_API_KEY=
TRUSTPILOT_API_SECRET=
TRUSTPILOT_BUSINESS_USER_ID=
